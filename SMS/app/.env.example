# School Management System - Environment Variables
# Copy this file to .env.local for development
# Or set these variables in Railway Dashboard for production

# ============================================================
# DEVELOPMENT ENVIRONMENT (.env.local)
# ============================================================

# API Configuration
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000
VITE_API_KEY=dev_key_12345

# Authentication
VITE_JWT_SECRET=dev_jwt_secret_change_in_production
VITE_SESSION_SECRET=dev_session_secret_change_in_production

# Database (Local)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sms_dev
MONGODB_URI=mongodb://localhost:27017/sms_dev

# School Settings
VITE_SCHOOL_NAME=Bridges Academy
VITE_SCHOOL_EMAIL=admin@bridgesacademy.edu
VITE_SCHOOL_PHONE=+1 (555) 012-3456
VITE_SCHOOL_ADDRESS=1200 Scholars Lane, Boston, MA 02108

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_USER_REGISTRATION=true
VITE_ENABLE_EMAIL_VERIFICATION=false

# Local Development
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug
VITE_MOCK_DATA=true

# ============================================================
# RAILWAY PRODUCTION ENVIRONMENT
# ============================================================

# API Configuration (Production)
# VITE_API_BASE_URL=https://your-api-domain.railway.app
# VITE_API_TIMEOUT=30000
# VITE_API_KEY=prod_key_from_railway

# Authentication (Production)
# VITE_JWT_SECRET=your_production_jwt_secret
# VITE_SESSION_SECRET=your_production_session_secret

# Database (Production)
# DATABASE_URL=your_production_database_url
# MONGODB_URI=your_production_mongodb_uri

# School Settings (Production)
# VITE_SCHOOL_NAME=Bridges Academy
# VITE_SCHOOL_EMAIL=admin@bridgesacademy.edu

# Feature Flags (Production)
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_USER_REGISTRATION=true
# VITE_ENABLE_EMAIL_VERIFICATION=true

# Production
# VITE_DEBUG_MODE=false
# VITE_LOG_LEVEL=error
# VITE_MOCK_DATA=false

# ============================================================
# LOCAL TUNNELING (For connecting Railway to Local Machine)
# ============================================================

# Option 1: ngrok - Public URL to your local machine
# VITE_LOCAL_TUNNEL_URL=https://abcd1234-5678-90ef-gh.ngrok.io

# Option 2: Cloudflare Tunnel
# VITE_CF_TUNNEL_URL=https://your-tunnel.trycloudflare.com

# Option 3: Docker + Docker Compose (Localhost)
# VITE_DOCKER_API_URL=http://host.docker.internal:3000

# ============================================================
# OPTIONAL: Advanced Configuration
# ============================================================

# Email Service
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@bridgesacademy.edu

# File Upload
# STORAGE_TYPE=local
# UPLOAD_PATH=./uploads
# MAX_FILE_SIZE=10485760

# Cache
# CACHE_TYPE=memory
# CACHE_TTL=3600

# Logging
# LOG_FILE=./logs/app.log
# LOG_MAX_SIZE=10M
# LOG_MAX_FILES=5
