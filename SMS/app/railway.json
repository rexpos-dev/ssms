{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run preview",
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "readiness": {
        "command": "curl http://localhost:5173 || exit 1",
        "interval": 10,
        "timeout": 5,
        "successThreshold": 1,
        "failureThreshold": 3
      },
      "liveness": {
        "command": "curl http://localhost:5173 || exit 1",
        "interval": 30,
        "timeout": 5,
        "successThreshold": 1,
        "failureThreshold": 5
      }
    }
  }
}
